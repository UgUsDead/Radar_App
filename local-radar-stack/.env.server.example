# Copy to .env on the office server and update values.

POSTGRES_DB=radar
POSTGRES_USER=radar
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5432

BACKEND_PORT=4000
MQTT_PORT=1883
